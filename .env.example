# ============================================================================
# Hush-Hush-Recruiter — copy to `.env` and adjust. Safe defaults run everything
# in demo mode with no external services and no real emails.
# ============================================================================

# ---------- Backend ----------
APP_ENV=development
# Comma-separated origins allowed to call the API (the two frontends).
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
# SQLite by default; swap for a Postgres URL in production.
DATABASE_URL=sqlite:///./data/hush.db

# Auth: "demo" (no Firebase needed) or "firebase" (verifies real ID tokens).
AUTH_MODE=demo
ADMIN_EMAILS=admin@doodle.com
# Leave empty for local dev. For a PUBLIC demo deploy, set a strong random value:
# admin then requires this token (typed as the password) so not just anyone can
# claim admin via a header. Ignored in firebase mode.
DEMO_ADMIN_TOKEN=
# Only for AUTH_MODE=firebase (also: pip install -r backend/requirements-firebase.txt)
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_FILE=

# Pipeline: "demo" (bundled sample data) or "live" (real GitHub API).
PIPELINE_MODE=demo
GITHUB_TOKEN=
SHORTLIST_SIZE=15
SCORE_THRESHOLD=0
# Autopilot: run the pipeline automatically every N minutes (0 = off).
AUTOPILOT_INTERVAL_MINUTES=0

# Email: "console" (log only, safe) or "smtp" (really send).
EMAIL_MODE=console
# Outreach is blocked unless this is true (and never sent to declined candidates).
ALLOW_OUTREACH=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_SENDER=no.reply.doodlerecruiter@gmail.com
EMAIL_PASSWORD=
APPLY_URL=http://localhost:5174

# ---------- Frontend (Vite) ----------
# Leave EMPTY for local dev & Codespaces: the frontends call the backend
# same-origin via the Vite "/api" proxy (see apps/*/vite.config.ts). Only set an
# absolute URL when deploying the frontends against a hosted backend, e.g.
# VITE_API_BASE_URL=https://hush-backend.onrender.com
VITE_API_BASE_URL=
# "demo" or "firebase". If unset, apps auto-detect from the Firebase vars below.
VITE_AUTH_MODE=demo
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
