# Dev-mode frontend env (auto-loaded by Vite; envDir is the repo root).
# Empty on purpose: the frontends call the backend SAME-ORIGIN via each Vite
# dev server's "/api" proxy (see apps/*/vite.config.ts). This is what makes the
# app work in GitHub Codespaces, where the browser cannot reach localhost:8000
# from a forwarded frontend origin. Do NOT set an absolute URL here in dev.
VITE_API_BASE_URL=
VITE_AUTH_MODE=demo
